{
  "name": "@forge/cli",
  "version": "1.0.0-alpha.1",
  "description": "Universal project scaffolder & developer assistant — plugin-driven, AI-powered, production-ready",
  "type": "module",
  "bin": {
    "forge": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./plugin": "./dist/core/plugin-manager.js",
    "./ai": "./dist/ai/provider.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "esbuild dist/index.js --bundle --platform=node --target=node22 --outfile=dist/bundle/forge.cjs",
    "build:exe": "npm run build && npm run build:bundle && mkdir -p dist/exe 2>nul && pkg dist/bundle/forge.cjs --targets node22-win-x64 --output dist/exe/forge.exe --public",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --apply src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "doctor": "node dist/index.js doctor"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "execa": "^9.3.0",
    "fast-glob": "^3.3.2",
    "giget": "^1.2.3",
    "handlebars": "^4.7.8",
    "inquirer": "^9.3.0",
    "openai": "^4.52.0",
    "ora": "^8.0.1",
    "picocolors": "^1.0.1",
    "semver": "^7.6.2",
    "validate-npm-package-name": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "esbuild": "^0.21.0",
    "pkg": "^5.8.1",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "code-generation",
    "developer-tools",
    "plugin-system",
    "ai-assistant"
  ]
}
